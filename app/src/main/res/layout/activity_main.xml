<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorThemeBackground"
    android:fitsSystemWindows="true"
    tools:context=".ui.activity.MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_title"
                    style="@style/TextAppearance.OStatus.Title" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/restart_system_ui_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/action_restart_systemui"
                    android:padding="11dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_power_restart"
                    app:tint="@color/colorIconButtonTint" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/home_subtitle"
                style="@style/TextAppearance.OStatus.Subtitle" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OStatus.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/module_status_indicator"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_status_indicator" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="模块状态"
                            style="@style/TextAppearance.OStatus.SectionTitle" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/module_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        style="@style/TextAppearance.OStatus.BodyPrimary"
                        tools:text="模块已连接，重启 SystemUI 后按当前配置生效" />

                    <TextView
                        android:id="@+id/framework_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        style="@style/TextAppearance.OStatus.BodySecondary"
                        tools:text="框架状态：LSPosed / API 101" />

                    <TextView
                        android:id="@+id/scope_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/TextAppearance.OStatus.BodySecondary"
                        tools:text="授权作用域：system, com.android.systemui" />

                    <TextView
                        android:id="@+id/version_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/TextAppearance.OStatus.BodySecondary"
                        tools:text="模块版本：1.100 (23)" />

                    <TextView
                        android:id="@+id/device_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="@style/TextAppearance.OStatus.BodySecondary"
                        tools:text="目标环境：ColorOS 16 / Android 16" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OStatus.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="核心设置"
                        style="@style/TextAppearance.OStatus.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:baselineAligned="false"
                        android:gravity="center_vertical"
                        android:minHeight="44dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="启用状态栏图标增强"
                                style="@style/TextAppearance.OStatus.BodyPrimary" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/icon_enhancement_switch"
                            style="@style/Widget.OStatus.Switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:translationY="1dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="所有设置修改后统一通过重启 SystemUI 生效，不做热更新。"
                        style="@style/TextAppearance.OStatus.BodyMuted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OStatus.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="规则数据"
                        style="@style/TextAppearance.OStatus.SectionTitle" />

                    <TextView
                        android:id="@+id/rules_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        style="@style/TextAppearance.OStatus.BodyPrimary"
                        tools:text="本地规则：0 条" />

                    <TextView
                        android:id="@+id/last_sync_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        style="@style/TextAppearance.OStatus.BodySecondary"
                        tools:text="最后同步：从未同步" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sync_rules_button"
                        style="@style/Widget.OStatus.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="14dp"
                        android:text="同步规则" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
