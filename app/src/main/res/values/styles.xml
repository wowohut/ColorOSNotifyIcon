<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.OStatus" parent="TextAppearance.Material3.BodyMedium" />

    <style name="TextAppearance.OStatus.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.OStatus.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.OStatus.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.OStatus.BodyPrimary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.OStatus.BodySecondary" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.OStatus.BodyMuted" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/colorTextMuted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.OStatus" parent="" />

    <style name="Widget.OStatus.Card" parent="">
        <item name="cardBackgroundColor">@color/colorSurfaceCard</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/colorCardStroke</item>
    </style>

    <style name="Widget.OStatus.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">44dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">10dp</item>
        <item name="backgroundTint">@color/colorPrimaryActionBackground</item>
        <item name="android:textColor">@color/colorPrimaryActionText</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.OStatus.Button.FloatingPill" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">50dp</item>
        <item name="backgroundTint">@color/colorPrimaryActionBackground</item>
        <item name="android:textColor">@color/colorPrimaryActionText</item>
        <item name="elevation">6dp</item>
    </style>

    <style name="Widget.OStatus.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:minHeight">44dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">10dp</item>
        <item name="backgroundTint">@color/colorSecondaryActionBackground</item>
        <item name="android:textColor">@color/colorSecondaryActionText</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.OStatus.Switch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:showText">false</item>
        <item name="android:splitTrack">false</item>
        <item name="android:switchMinWidth">46dp</item>
        <item name="android:switchPadding">0dp</item>
        <item name="android:thumbTextPadding">0dp</item>
        <item name="android:thumb">@drawable/bg_switch_thumb</item>
        <item name="android:track">@drawable/bg_switch_track</item>
    </style>

    <style name="ThemeOverlay.OStatus.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.OStatus.Dialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.OStatus.DialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.OStatus.DialogButton.Negative</item>
    </style>

    <style name="ShapeAppearanceOverlay.OStatus.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Widget.OStatus.DialogButton.Positive" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorDialogPositiveAction</item>
    </style>

    <style name="Widget.OStatus.DialogButton.Negative" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>
</resources>
